<?xml version="1.0" encoding="utf-8"?>
<!-- UFactory 850 6-DoF arm + real xArm Gripper, on the 205 mm robot mount
     pedestal. All link offsets, joint limits, and meshes come from
     UFactory's xarm_ros2 description package (the same source the MJCF
     uses) — the browser viewer loads this via urdf-loader and applies
     joint state from the live world-state SSE feed. -->
<robot name="uf850">

  <material name="white"><color rgba="0.95 0.95 0.95 1.0"/></material>
  <material name="grey"><color rgba="0.35 0.35 0.35 1.0"/></material>
  <material name="silver"><color rgba="0.78 0.78 0.78 1.0"/></material>
  <material name="black"><color rgba="0.12 0.12 0.12 1.0"/></material>

  <!-- World mount → pedestal → link_base. The pedestal is part of the
       robot installation (mounting kit), not a "table". -->
  <link name="world"/>
  <link name="mount">
    <visual>
      <origin xyz="0 0 0.10"/>
      <geometry><cylinder length="0.20" radius="0.07"/></geometry>
      <material name="grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.20"/>
      <geometry><cylinder length="0.01" radius="0.10"/></geometry>
      <material name="grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.00"/>
      <geometry><cylinder length="0.01" radius="0.12"/></geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="mount_to_world" type="fixed">
    <parent link="world"/><child link="mount"/>
    <origin xyz="0 0 0"/>
  </joint>

  <link name="link_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link_base.stl"/></geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <origin xyz="-0.00025599 -2.8579e-06 0.085749"/>
      <mass value="2.2684"/>
      <inertia ixx="0.0063949" ixy="-8.0653e-07" ixz="-2.1841e-05"
               iyy="0.0064375" iyz="-4.2181e-07" izz="0.0048631"/>
    </inertial>
  </link>
  <joint name="link_base_to_mount" type="fixed">
    <parent link="mount"/><child link="link_base"/>
    <origin xyz="0 0 0.205"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link1.stl"/></geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <origin xyz="0 0 -0.05"/><mass value="2.16"/>
      <inertia ixx="0.0085" ixy="0" ixz="0" iyy="0.0085" iyz="0" izz="0.0044"/>
    </inertial>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="link_base"/><child link="link1"/>
    <origin xyz="0 0 0.364" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.283185" upper="6.283185" effort="200" velocity="3.14"/>
    <dynamics damping="16.6" friction="9.6"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link2.stl"/></geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <origin xyz="0.2 0 0"/><mass value="2.04"/>
      <inertia ixx="0.0066" ixy="0" ixz="0" iyy="0.022" iyz="0" izz="0.022"/>
    </inertial>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="link1"/><child link="link2"/>
    <origin xyz="0 0 0" rpy="1.5708 -1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.3038346" upper="2.3038346" effort="200" velocity="3.14"/>
    <dynamics damping="12.5" friction="12.1"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link3.stl"/></geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <origin xyz="0.08 0.2 0"/><mass value="1.7"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.015"/>
    </inertial>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="link2"/><child link="link3"/>
    <origin xyz="0.39 0 0" rpy="-3.1416 0 -1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-4.2236968" upper="0.061087" effort="90" velocity="3.14"/>
    <dynamics damping="4.0" friction="5.5"/>
  </joint>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link4.stl"/></geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0"/><mass value="1.34"/>
      <inertia ixx="0.0032" ixy="0" ixz="0" iyy="0.0032" iyz="0" izz="0.0017"/>
    </inertial>
  </link>
  <joint name="joint4" type="revolute">
    <parent link="link3"/><child link="link4"/>
    <origin xyz="0.15 0.426 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.283185" upper="6.283185" effort="68" velocity="3.14"/>
    <dynamics damping="3.6" friction="2.2"/>
  </joint>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link5.stl"/></geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0"/><mass value="1.16"/>
      <inertia ixx="0.0026" ixy="0" ixz="0" iyy="0.0026" iyz="0" izz="0.0013"/>
    </inertial>
  </link>
  <joint name="joint5" type="revolute">
    <parent link="link4"/><child link="link5"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.1642" upper="2.1642" effort="19" velocity="3.14"/>
    <dynamics damping="3.45" friction="3.2"/>
  </joint>

  <link name="link6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link6.stl"/></geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0"/><mass value="0.17"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="joint6" type="revolute">
    <parent link="link5"/><child link="link6"/>
    <origin xyz="0 -0.09 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.283185" upper="6.283185" effort="19" velocity="3.14"/>
    <dynamics damping="3.4" friction="1.1"/>
  </joint>

  <!-- Real xArm Gripper — base + 4-bar linkage with mimic joints. -->
  <link name="xarm_gripper_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/gripper/base_link.stl"/></geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <origin xyz="-0.00065489 -0.0018497 0.048028"/>
      <mass value="0.54156"/>
      <inertia ixx="0.00047106" ixy="3.9292e-07" ixz="2.6537e-06"
               iyy="0.00033072" iyz="-1.0975e-05" izz="0.00025642"/>
    </inertial>
  </link>
  <joint name="xarm_gripper_fix" type="fixed">
    <parent link="link6"/><child link="xarm_gripper_base_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <link name="left_outer_knuckle">
    <visual><origin xyz="0 0 0"/><geometry><mesh filename="meshes/gripper/left_outer_knuckle.stl"/></geometry><material name="silver"/></visual>
    <inertial><origin xyz="0 0.021559 0.015181"/><mass value="0.033618"/><inertia ixx="1.9111e-05" ixy="0" ixz="0" iyy="6.6256e-06" iyz="0" izz="1.3185e-05"/></inertial>
  </link>
  <joint name="drive_joint" type="revolute">
    <parent link="xarm_gripper_base_link"/><child link="left_outer_knuckle"/>
    <origin xyz="0 0.035 0.059098" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.85" effort="50" velocity="2"/>
  </joint>

  <link name="left_finger">
    <visual><origin xyz="0 0 0"/><geometry><mesh filename="meshes/gripper/left_finger.stl"/></geometry><material name="black"/></visual>
    <inertial><origin xyz="0 -0.016413 0.029258"/><mass value="0.048304"/><inertia ixx="1.7493e-05" ixy="0" ixz="0" iyy="1.7225e-05" iyz="0" izz="5.1466e-06"/></inertial>
  </link>
  <joint name="left_finger_joint" type="revolute">
    <parent link="left_outer_knuckle"/><child link="left_finger"/>
    <origin xyz="0 0.035465 0.042039" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.85" effort="50" velocity="2"/>
    <mimic joint="drive_joint" multiplier="1" offset="0"/>
  </joint>

  <link name="left_inner_knuckle">
    <visual><origin xyz="0 0 0"/><geometry><mesh filename="meshes/gripper/left_inner_knuckle.stl"/></geometry><material name="silver"/></visual>
    <inertial><origin xyz="0 0.022047 0.026133"/><mass value="0.023013"/><inertia ixx="6.095e-06" ixy="0" ixz="0" iyy="6.020e-06" iyz="0" izz="5.079e-06"/></inertial>
  </link>
  <joint name="left_inner_knuckle_joint" type="revolute">
    <parent link="xarm_gripper_base_link"/><child link="left_inner_knuckle"/>
    <origin xyz="0 0.02 0.074098" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.85" effort="50" velocity="2"/>
    <mimic joint="drive_joint" multiplier="1" offset="0"/>
  </joint>

  <link name="right_outer_knuckle">
    <visual><origin xyz="0 0 0"/><geometry><mesh filename="meshes/gripper/right_outer_knuckle.stl"/></geometry><material name="silver"/></visual>
    <inertial><origin xyz="0 -0.021559 0.015181"/><mass value="0.033618"/><inertia ixx="1.9111e-05" ixy="0" ixz="0" iyy="6.6256e-06" iyz="0" izz="1.3185e-05"/></inertial>
  </link>
  <joint name="right_outer_knuckle_joint" type="revolute">
    <parent link="xarm_gripper_base_link"/><child link="right_outer_knuckle"/>
    <origin xyz="0 -0.035 0.059098" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.85" effort="50" velocity="2"/>
    <mimic joint="drive_joint" multiplier="1" offset="0"/>
  </joint>

  <link name="right_finger">
    <visual><origin xyz="0 0 0"/><geometry><mesh filename="meshes/gripper/right_finger.stl"/></geometry><material name="black"/></visual>
    <inertial><origin xyz="0 0.016413 0.029258"/><mass value="0.048304"/><inertia ixx="1.7493e-05" ixy="0" ixz="0" iyy="1.7225e-05" iyz="0" izz="5.1466e-06"/></inertial>
  </link>
  <joint name="right_finger_joint" type="revolute">
    <parent link="right_outer_knuckle"/><child link="right_finger"/>
    <origin xyz="0 -0.035465 0.042039" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.85" effort="50" velocity="2"/>
    <mimic joint="drive_joint" multiplier="1" offset="0"/>
  </joint>

  <link name="right_inner_knuckle">
    <visual><origin xyz="0 0 0"/><geometry><mesh filename="meshes/gripper/right_inner_knuckle.stl"/></geometry><material name="silver"/></visual>
    <inertial><origin xyz="0 -0.022047 0.026133"/><mass value="0.023013"/><inertia ixx="6.095e-06" ixy="0" ixz="0" iyy="6.020e-06" iyz="0" izz="5.079e-06"/></inertial>
  </link>
  <joint name="right_inner_knuckle_joint" type="revolute">
    <parent link="xarm_gripper_base_link"/><child link="right_inner_knuckle"/>
    <origin xyz="0 -0.02 0.074098" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.85" effort="50" velocity="2"/>
    <mimic joint="drive_joint" multiplier="1" offset="0"/>
  </joint>

  <!-- TCP at the grasp center, 172 mm from the wrist flange. -->
  <link name="tcp"/>
  <joint name="joint_tcp" type="fixed">
    <parent link="xarm_gripper_base_link"/><child link="tcp"/>
    <origin xyz="0 0 0.172" rpy="0 0 0"/>
  </joint>

</robot>

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://farm.dev/schemas/run_record.v1",
  "title": "FARM Run Record v1",
  "type": "object",
  "required": [
    "run_id",
    "workspace_id",
    "task",
    "plan_dag",
    "nodes",
    "wall_clock_ms",
    "cost_usd",
    "replayable",
    "content_hash",
    "calibration_hash",
    "edge_agent_version",
    "protocol_version",
    "capability_card_schema_url",
    "started_at",
    "ended_at"
  ],
  "additionalProperties": true,
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "string"
    },
    "plan_dag": {
      "type": "object",
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "chosen_backend",
          "fallback_events",
          "action_chunks",
          "observations",
          "safety_events",
          "critic_notes"
        ],
        "additionalProperties": true,
        "properties": {
          "node_id": {"type": "string"},
          "chosen_backend": {"type": "string"},
          "reason": {"type": "string"},
          "fallback_events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from_backend", "to_backend", "trigger", "at_ms"],
              "properties": {
                "from_backend": {"type": "string"},
                "to_backend": {"type": "string"},
                "trigger": {"type": "string"},
                "at_ms": {"type": "integer"}
              }
            }
          },
          "action_chunks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["index", "timestamp_ms"],
              "properties": {
                "index": {"type": "integer"},
                "timestamp_ms": {"type": "integer"}
              }
            }
          },
          "observations": {
            "type": "array"
          },
          "safety_events": {
            "type": "array"
          },
          "critic_notes": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "wall_clock_ms": {
      "type": "integer",
      "minimum": 0
    },
    "cost_usd": {
      "type": "number",
      "minimum": 0
    },
    "replayable": {"type": "boolean"},
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "calibration_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "edge_agent_version": {"type": "string"},
    "protocol_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "capability_card_schema_url": {"type": "string"},
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "signature": {"type": "string"},
    "operator_label": {
      "type": ["object", "null"],
      "properties": {
        "outcome": {"type": "string", "enum": ["pass", "fail"]},
        "notes": {"type": "string"}
      }
    }
  }
}

<?xml version="1.0" encoding="utf-8"?>
<robot name="uf850">

  <!-- Materials -->
  <material name="white"><color rgba="0.95 0.95 0.95 1.0"/></material>
  <material name="grey"><color rgba="0.35 0.35 0.35 1.0"/></material>
  <material name="orange"><color rgba="0.95 0.55 0.20 1.0"/></material>

  <!-- Base link -->
  <link name="link_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link_base.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/collision/link_base.stl"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.00025599 -2.8579e-06 0.085749"/>
      <mass value="2.2684"/>
      <inertia ixx="0.0063949" ixy="-8.0653e-07" ixz="-2.1841e-05"
               iyy="0.0064375" iyz="-4.2181e-07" izz="0.0048631"/>
    </inertial>
  </link>

  <!-- Link 1 -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link1.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/collision/link1.stl"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.05"/><mass value="2.16"/>
      <inertia ixx="0.0085" ixy="0" ixz="0" iyy="0.0085" iyz="0" izz="0.0044"/>
    </inertial>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="link_base"/><child link="link1"/>
    <origin xyz="0 0 0.364" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.283185" upper="6.283185" effort="200" velocity="3.14"/>
    <dynamics damping="16.6" friction="9.6"/>
  </joint>

  <!-- Link 2 -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link2.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/collision/link2.stl"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.2 0 0"/><mass value="2.04"/>
      <inertia ixx="0.0066" ixy="0" ixz="0" iyy="0.022" iyz="0" izz="0.022"/>
    </inertial>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="link1"/><child link="link2"/>
    <origin xyz="0 0 0" rpy="1.5708 -1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.3038346" upper="2.3038346" effort="200" velocity="3.14"/>
    <dynamics damping="12.5" friction="12.1"/>
  </joint>

  <!-- Link 3 -->
  <link name="link3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link3.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/collision/link3.stl"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.08 0.2 0"/><mass value="1.7"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.015"/>
    </inertial>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="link2"/><child link="link3"/>
    <origin xyz="0.39 0 0" rpy="-3.1416 0 -1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-4.2236968" upper="0.061087" effort="90" velocity="3.14"/>
    <dynamics damping="4.0" friction="5.5"/>
  </joint>

  <!-- Link 4 -->
  <link name="link4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link4.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/collision/link4.stl"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/><mass value="1.34"/>
      <inertia ixx="0.0032" ixy="0" ixz="0" iyy="0.0032" iyz="0" izz="0.0017"/>
    </inertial>
  </link>
  <joint name="joint4" type="revolute">
    <parent link="link3"/><child link="link4"/>
    <origin xyz="0.15 0.426 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.283185" upper="6.283185" effort="68" velocity="3.14"/>
    <dynamics damping="3.6" friction="2.2"/>
  </joint>

  <!-- Link 5 -->
  <link name="link5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link5.stl"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/collision/link5.stl"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/><mass value="1.16"/>
      <inertia ixx="0.0026" ixy="0" ixz="0" iyy="0.0026" iyz="0" izz="0.0013"/>
    </inertial>
  </link>
  <joint name="joint5" type="revolute">
    <parent link="link4"/><child link="link5"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.1642" upper="2.1642" effort="19" velocity="3.14"/>
    <dynamics damping="3.45" friction="3.2"/>
  </joint>

  <!-- Link 6 -->
  <link name="link6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/visual/link6.stl"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/collision/link6.stl"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/><mass value="0.17"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="joint6" type="revolute">
    <parent link="link5"/><child link="link6"/>
    <origin xyz="0 -0.09 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.283185" upper="6.283185" effort="19" velocity="3.14"/>
    <dynamics damping="3.4" friction="1.1"/>
  </joint>

  <!-- Tool tip frame (oriented so +Z points outward along the gripper axis) -->
  <link name="link_eef"/>
  <joint name="joint_eef" type="fixed">
    <parent link="link6"/><child link="link_eef"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Simple parallel-jaw gripper -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.07 0.04 0.05"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.07 0.04 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.025"/><mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="joint_gripper_base" type="fixed">
    <parent link="link_eef"/><child link="gripper_base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="finger_left">
    <visual>
      <origin xyz="-0.005 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.010 0.025 0.06"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="-0.005 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.010 0.025 0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.005 0 0.03"/><mass value="0.03"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="finger_left_joint" type="prismatic">
    <parent link="gripper_base"/><child link="finger_left"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.040" upper="-0.012" effort="50" velocity="0.5"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="finger_right">
    <visual>
      <origin xyz="0.005 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.010 0.025 0.06"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0.005 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.010 0.025 0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.005 0 0.03"/><mass value="0.03"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="finger_right_joint" type="prismatic">
    <parent link="gripper_base"/><child link="finger_right"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.012" upper="0.040" effort="50" velocity="0.5"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <!-- Tool center point at the grasp center between the fingers. -->
  <link name="tcp"/>
  <joint name="joint_tcp" type="fixed">
    <parent link="gripper_base"/><child link="tcp"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

</robot>

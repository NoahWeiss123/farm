<mujoco model="uf850">
  <compiler angle="radian" meshdir="meshes/visual" autolimits="true"/>

  <option timestep="0.002" iterations="50" solver="Newton" gravity="0 0 -9.81">
    <flag warmstart="enable"/>
  </option>

  <!-- Collision groups via contype/conaffinity bitmasks. Pairs collide iff
       (a.contype & b.conaffinity) | (b.contype & a.conaffinity) is nonzero.

         floor:   contype=1  conaffinity=2   collides with props only
         arm:     contype=4  conaffinity=2   collides with props only (no floor)
         prop:    contype=2  conaffinity=7   collides with everything
  -->
  <default>
    <default class="uf850">
      <joint limited="true" damping="1.0" frictionloss="0.5"/>
      <geom contype="4" conaffinity="2" group="1"/>
      <!-- Stiff PD. Real servo loops on the UF850 use current/torque
           inner loops and integrate out gravity sag — at the position
           layer they behave like very-high-kp controllers. kp=900 with
           kv=60 and the per-actuator `forcerange` set to motor limits
           gives tight tracking without instability. -->
      <position kp="900" kv="60"/>
    </default>
    <default class="gripper_drive">
      <joint limited="true" damping="0.5" frictionloss="0.05" armature="0.01"/>
      <geom contype="4" conaffinity="2" group="1"
            friction="2.0 0.05 0.001" condim="4"/>
      <position kp="200" kv="10" forcerange="-50 50"/>
    </default>
  </default>

  <asset>
    <mesh name="m_base"  file="link_base.stl"/>
    <mesh name="m_link1" file="link1.stl"/>
    <mesh name="m_link2" file="link2.stl"/>
    <mesh name="m_link3" file="link3.stl"/>
    <mesh name="m_link4" file="link4.stl"/>
    <mesh name="m_link5" file="link5.stl"/>
    <mesh name="m_link6" file="link6.stl"/>
    <mesh name="m_grip_base"  file="../gripper/base_link.stl"/>
    <mesh name="m_grip_l_ok"  file="../gripper/left_outer_knuckle.stl"/>
    <mesh name="m_grip_l_ik"  file="../gripper/left_inner_knuckle.stl"/>
    <mesh name="m_grip_l_fg"  file="../gripper/left_finger.stl"/>
    <mesh name="m_grip_r_ok"  file="../gripper/right_outer_knuckle.stl"/>
    <mesh name="m_grip_r_ik"  file="../gripper/right_inner_knuckle.stl"/>
    <mesh name="m_grip_r_fg"  file="../gripper/right_finger.stl"/>
    <material name="white" rgba="0.95 0.95 0.95 1"/>
    <material name="grey"  rgba="0.35 0.35 0.35 1"/>
    <material name="silver" rgba="0.78 0.78 0.78 1"/>
    <material name="black" rgba="0.12 0.12 0.12 1"/>
    <texture name="tex_grid" type="2d" builtin="checker" rgb1="0.85 0.85 0.85" rgb2="0.70 0.70 0.70" width="300" height="300"/>
    <material name="mat_grid" texture="tex_grid" texrepeat="8 8" texuniform="true" reflectance="0.05"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 2" dir="0 0 -1"/>
    <light directional="true" diffuse="0.3 0.3 0.3" pos="-1 -1 2" dir="1 1 -1"/>
    <geom name="floor" type="plane" size="2 2 0.1" material="mat_grid"
          friction="1.0 0.1 0.01" contype="1" conaffinity="2"/>

    <!-- Robot mounting pedestal. Real UF850 deployments bolt the arm to a
         stand or mounting plate; the official mounting kit is ~200 mm tall
         and ~200 mm wide. The arm's link_base sits on top of this. -->
    <body name="mount" pos="0 0 0.10">
      <geom name="mount_top"  type="cylinder" size="0.10 0.005" pos="0 0 0.10"
            material="grey" contype="4" conaffinity="2"/>
      <geom name="mount_col"  type="cylinder" size="0.07 0.10"  pos="0 0 0"
            material="grey" contype="4" conaffinity="2"/>
      <geom name="mount_base" type="cylinder" size="0.12 0.005" pos="0 0 -0.10"
            material="grey" contype="4" conaffinity="2"/>
    </body>

    <body name="link_base" pos="0 0 0.205" childclass="uf850">
      <geom type="mesh" mesh="m_base" material="white"/>

      <!-- Damping comes from xarm_ros2; frictionloss reduced 10× because the
           xacro values represent uncompensated mechanical stiction. The
           real UF850 servos run a torque/current loop that cancels most of
           that — the values left here roughly represent residual friction
           after closed-loop compensation. -->
      <body name="link1" pos="0 0 0.364">
        <inertial pos="0 0 -0.05" mass="2.16" diaginertia="0.0085 0.0085 0.0044"/>
        <joint name="joint1" axis="0 0 1" range="-6.283185 6.283185" damping="2.0" frictionloss="0.5"/>
        <geom type="mesh" mesh="m_link1" material="white"/>

        <body name="link2" pos="0 0 0" euler="1.5708 -1.5708 0">
          <inertial pos="0.2 0 0" mass="2.04" diaginertia="0.0066 0.022 0.022"/>
          <joint name="joint2" axis="0 0 1" range="-2.3038346 2.3038346" damping="2.0" frictionloss="0.5"/>
          <geom type="mesh" mesh="m_link2" material="white"/>

          <body name="link3" pos="0.39 0 0" euler="-3.1416 0 -1.5708">
            <inertial pos="0.08 0.2 0" mass="1.7" diaginertia="0.005 0.015 0.015"/>
            <joint name="joint3" axis="0 0 1" range="-4.2236968 0.061087" damping="1.5" frictionloss="0.3"/>
            <geom type="mesh" mesh="m_link3" material="white"/>

            <body name="link4" pos="0.15 0.426 0" euler="-1.5708 0 0">
              <inertial pos="0 0 0" mass="1.34" diaginertia="0.0032 0.0032 0.0017"/>
              <joint name="joint4" axis="0 0 1" range="-6.283185 6.283185" damping="1.0" frictionloss="0.2"/>
              <geom type="mesh" mesh="m_link4" material="white"/>

              <body name="link5" pos="0 0 0" euler="-1.5708 0 0">
                <inertial pos="0 0 0" mass="1.16" diaginertia="0.0026 0.0026 0.0013"/>
                <joint name="joint5" axis="0 0 1" range="-2.1642 2.1642" damping="0.8" frictionloss="0.2"/>
                <geom type="mesh" mesh="m_link5" material="white"/>

                <body name="link6" pos="0 -0.09 0" euler="1.5708 0 0">
                  <inertial pos="0 0 0" mass="0.17" diaginertia="0.0001 0.0001 0.0001"/>
                  <joint name="joint6" axis="0 0 1" range="-6.283185 6.283185" damping="0.5" frictionloss="0.1"/>
                  <geom type="mesh" mesh="m_link6" material="grey"/>

                  <!-- xArm Gripper. The visual is the real ``base_link.stl``
                       mesh from UFactory's xarm_ros2 package, but physics
                       is two prismatic finger sliders (left/right). The
                       full 4-bar linkage works visually in MuJoCo when
                       wired with equality constraints, but the constraint
                       solver becomes unstable under the wrist's heavier
                       inertia load during motion — we trade physical
                       fidelity of the linkage for stable arm motion.
                       Finger inner faces land symmetrically; the inner
                       knuckle / outer knuckle visuals are fixed at their
                       open positions so the gripper still LOOKS right. -->
                  <body name="xarm_gripper_base_link" pos="0 0 0">
                    <inertial pos="-0.00065489 -0.0018497 0.048028"
                              mass="0.54156"
                              diaginertia="0.00047106 0.00033072 0.00025642"/>
                    <geom type="mesh" mesh="m_grip_base" material="white"/>
                    <!-- Decorative knuckles (no joints, fixed at open). -->
                    <geom type="mesh" mesh="m_grip_l_ok" material="silver"
                          pos="0 0.035 0.059098" contype="0" conaffinity="0" group="2"/>
                    <geom type="mesh" mesh="m_grip_l_ik" material="silver"
                          pos="0 0.02 0.074098" contype="0" conaffinity="0" group="2"/>
                    <geom type="mesh" mesh="m_grip_r_ok" material="silver"
                          pos="0 -0.035 0.059098" contype="0" conaffinity="0" group="2"/>
                    <geom type="mesh" mesh="m_grip_r_ik" material="silver"
                          pos="0 -0.02 0.074098" contype="0" conaffinity="0" group="2"/>

                    <!-- Simple parallel-jaw fingers — physics-only. -->
                    <body name="left_finger" pos="0 0.035 0.100" childclass="gripper_drive">
                      <inertial pos="0 0 0.03" mass="0.05" diaginertia="2e-5 2e-5 1e-5"/>
                      <joint name="left_finger_joint" type="slide"
                             axis="0 -1 0" range="0 0.035" damping="0.5"/>
                      <!-- Slim collision box approximating the finger pad. -->
                      <geom type="box" size="0.008 0.005 0.030" pos="0 -0.005 0.030"
                            material="black" friction="3.0 0.05 0.001" condim="6"/>
                    </body>
                    <body name="right_finger" pos="0 -0.035 0.100" childclass="gripper_drive">
                      <inertial pos="0 0 0.03" mass="0.05" diaginertia="2e-5 2e-5 1e-5"/>
                      <joint name="right_finger_joint" type="slide"
                             axis="0 1 0" range="0 0.035" damping="0.5"/>
                      <geom type="box" size="0.008 0.005 0.030" pos="0 0.005 0.030"
                            material="black" friction="3.0 0.05 0.001" condim="6"/>
                    </body>

                    <!-- TCP at the grasp center, 172 mm from the flange. -->
                    <site name="tcp" pos="0 0 0.172" size="0.005" rgba="1 0 0 0.6"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Couple the two fingers so closing one closes the other symmetrically. -->
  <equality>
    <joint joint1="right_finger_joint" joint2="left_finger_joint" polycoef="0 1 0 0 0"
           solref="0.001 1" solimp="0.999 0.9999 0.001"/>
  </equality>

  <actuator>
    <!-- kp/kv on `position` actuators only apply when the actuator has
         `class="uf850"`. Without an explicit class, MuJoCo gives them
         kp=1 — barely enough force to overcome joint damping, never
         mind gravity. The bug that turned the demo into a noodle. -->
    <position name="a_joint1" joint="joint1" class="uf850" ctrlrange="-6.28 6.28" forcerange="-200 200"/>
    <position name="a_joint2" joint="joint2" class="uf850" ctrlrange="-2.30 2.30" forcerange="-200 200"/>
    <position name="a_joint3" joint="joint3" class="uf850" ctrlrange="-4.22 0.06" forcerange="-90 90"/>
    <position name="a_joint4" joint="joint4" class="uf850" ctrlrange="-6.28 6.28" forcerange="-68 68"/>
    <position name="a_joint5" joint="joint5" class="uf850" ctrlrange="-2.16 2.16" forcerange="-19 19"/>
    <position name="a_joint6" joint="joint6" class="uf850" ctrlrange="-6.28 6.28" forcerange="-19 19"/>
    <!-- ctrl=0 → fully open (35 mm half-stroke), ctrl=0.025 → closed on
         a 25 mm block with small compression. -->
    <position name="a_gripper" joint="left_finger_joint" ctrlrange="0 0.035" class="gripper_drive"/>
  </actuator>
</mujoco>

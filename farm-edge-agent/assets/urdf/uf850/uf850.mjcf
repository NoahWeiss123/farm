<mujoco model="uf850">
  <compiler angle="radian" meshdir="meshes/visual" autolimits="true"/>

  <option timestep="0.002" iterations="50" solver="Newton" gravity="0 0 -9.81">
    <flag warmstart="enable"/>
  </option>

  <default>
    <default class="uf850">
      <joint limited="true" damping="1.0" frictionloss="0.5"/>
      <geom contype="1" conaffinity="1" group="1"/>
      <position kp="2000" kv="200"/>
    </default>
    <default class="finger">
      <joint limited="true" damping="5.0" frictionloss="0.5"/>
      <geom contype="1" conaffinity="1" friction="2.5 0.05 0.001" condim="4"/>
      <position kp="200" kv="40"/>
    </default>
  </default>

  <asset>
    <mesh name="m_base"  file="link_base.stl"/>
    <mesh name="m_link1" file="link1.stl"/>
    <mesh name="m_link2" file="link2.stl"/>
    <mesh name="m_link3" file="link3.stl"/>
    <mesh name="m_link4" file="link4.stl"/>
    <mesh name="m_link5" file="link5.stl"/>
    <mesh name="m_link6" file="link6.stl"/>
    <material name="white" rgba="0.95 0.95 0.95 1"/>
    <material name="grey"  rgba="0.35 0.35 0.35 1"/>
    <material name="orange" rgba="0.95 0.55 0.20 1"/>
    <texture name="tex_grid" type="2d" builtin="checker" rgb1="0.85 0.85 0.85" rgb2="0.70 0.70 0.70" width="300" height="300"/>
    <material name="mat_grid" texture="tex_grid" texrepeat="8 8" texuniform="true" reflectance="0.05"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 2" dir="0 0 -1"/>
    <light directional="true" diffuse="0.3 0.3 0.3" pos="-1 -1 2" dir="1 1 -1"/>
    <geom name="floor" type="plane" size="2 2 0.1" material="mat_grid" friction="1.0 0.1 0.01" contype="1" conaffinity="1"/>

    <!-- Working table: 0.55 m × 0.45 m, top at z = 0.26 m, centered at y = -0.70 m.
         Height + standoff chosen so pick poses live in UF850's kinematic
         sweet spot (z > ~0.27 m, |y| > 0.60 m) — the wrist stays clear of
         joint5 limit so IK + PD are stable. -->
    <body name="table" pos="0 -0.70 0.13">
      <geom name="table_top"   type="box" size="0.275 0.225 0.005" pos="0 0 0.13" rgba="0.78 0.65 0.45 1.0" friction="1.0 0.05 0.001" contype="1" conaffinity="1"/>
      <geom name="table_leg_a" type="box" size="0.012 0.012 0.065" pos=" 0.25 -0.20 0.065" rgba="0.40 0.30 0.22 1.0"/>
      <geom name="table_leg_b" type="box" size="0.012 0.012 0.065" pos="-0.25 -0.20 0.065" rgba="0.40 0.30 0.22 1.0"/>
      <geom name="table_leg_c" type="box" size="0.012 0.012 0.065" pos=" 0.25  0.20 0.065" rgba="0.40 0.30 0.22 1.0"/>
      <geom name="table_leg_d" type="box" size="0.012 0.012 0.065" pos="-0.25  0.20 0.065" rgba="0.40 0.30 0.22 1.0"/>
    </body>

    <body name="link_base" pos="0 0 0" childclass="uf850">
      <geom type="mesh" mesh="m_base" material="white"/>

      <body name="link1" pos="0 0 0.364">
        <inertial pos="0 0 -0.05" mass="2.16" diaginertia="0.0085 0.0085 0.0044"/>
        <joint name="joint1" axis="0 0 1" range="-6.283185 6.283185" damping="16.6" frictionloss="9.6"/>
        <geom type="mesh" mesh="m_link1" material="white"/>

        <body name="link2" pos="0 0 0" euler="1.5708 -1.5708 0">
          <inertial pos="0.2 0 0" mass="2.04" diaginertia="0.0066 0.022 0.022"/>
          <joint name="joint2" axis="0 0 1" range="-2.3038346 2.3038346" damping="12.5" frictionloss="12.1"/>
          <geom type="mesh" mesh="m_link2" material="white"/>

          <body name="link3" pos="0.39 0 0" euler="-3.1416 0 -1.5708">
            <inertial pos="0.08 0.2 0" mass="1.7" diaginertia="0.005 0.015 0.015"/>
            <joint name="joint3" axis="0 0 1" range="-4.2236968 0.061087" damping="4.0" frictionloss="5.5"/>
            <geom type="mesh" mesh="m_link3" material="white"/>

            <body name="link4" pos="0.15 0.426 0" euler="-1.5708 0 0">
              <inertial pos="0 0 0" mass="1.34" diaginertia="0.0032 0.0032 0.0017"/>
              <joint name="joint4" axis="0 0 1" range="-6.283185 6.283185" damping="3.6" frictionloss="2.2"/>
              <geom type="mesh" mesh="m_link4" material="white"/>

              <body name="link5" pos="0 0 0" euler="-1.5708 0 0">
                <inertial pos="0 0 0" mass="1.16" diaginertia="0.0026 0.0026 0.0013"/>
                <joint name="joint5" axis="0 0 1" range="-2.1642 2.1642" damping="3.45" frictionloss="3.2"/>
                <geom type="mesh" mesh="m_link5" material="white"/>

                <body name="link6" pos="0 -0.09 0" euler="1.5708 0 0">
                  <inertial pos="0 0 0" mass="0.17" diaginertia="0.0001 0.0001 0.0001"/>
                  <joint name="joint6" axis="0 0 1" range="-6.283185 6.283185" damping="3.4" frictionloss="1.1"/>
                  <geom type="mesh" mesh="m_link6" material="grey"/>

                  <!-- Gripper base bolted to the flange -->
                  <body name="gripper_base" pos="0 0 0">
                    <inertial pos="0 0 0.025" mass="0.15" diaginertia="0.0001 0.0001 0.0001"/>
                    <geom type="box" size="0.035 0.020 0.025" pos="0 0 0.025" material="grey"/>

                    <body name="finger_left" pos="0 0 0.05" childclass="finger">
                      <inertial pos="-0.005 0 0.03" mass="0.03" diaginertia="1e-5 1e-5 1e-5"/>
                      <joint name="finger_left_joint" type="slide" axis="1 0 0" range="-0.040 -0.012"/>
                      <geom type="box" size="0.005 0.0125 0.030" pos="-0.005 0 0.030" material="orange"/>
                    </body>
                    <body name="finger_right" pos="0 0 0.05" childclass="finger">
                      <inertial pos="0.005 0 0.03" mass="0.03" diaginertia="1e-5 1e-5 1e-5"/>
                      <joint name="finger_right_joint" type="slide" axis="1 0 0" range="0.012 0.040"/>
                      <geom type="box" size="0.005 0.0125 0.030" pos="0.005 0 0.030" material="orange"/>
                    </body>

                    <!-- TCP at the grasp center (between the fingers).
                         Picking a block at z=block_z puts TCP at block_z. -->
                    <site name="tcp" pos="0 0 0.08" size="0.005" rgba="1 0 0 0.6"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="a_joint1" joint="joint1" ctrlrange="-6.28 6.28"/>
    <position name="a_joint2" joint="joint2" ctrlrange="-2.30 2.30"/>
    <position name="a_joint3" joint="joint3" ctrlrange="-4.22 0.06"/>
    <position name="a_joint4" joint="joint4" ctrlrange="-6.28 6.28"/>
    <position name="a_joint5" joint="joint5" ctrlrange="-2.16 2.16"/>
    <position name="a_joint6" joint="joint6" ctrlrange="-6.28 6.28"/>
    <position name="a_finger_left"  joint="finger_left_joint"  ctrlrange="-0.040 -0.012" class="finger"/>
    <position name="a_finger_right" joint="finger_right_joint" ctrlrange="0.012 0.040"   class="finger"/>
  </actuator>
</mujoco>

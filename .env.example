# FARM environment variables
#
# Copy this file to `.env` (already gitignored) and fill in real values.
# Most code reads these via `farm_edge_agent.config.loader` or the worker's
# `wrangler secret put` flow — see DEPLOY.md for production secrets handling.
#
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED IMMEDIATELY
# ─────────────────────────────────────────────────────────────────────────────
# Drives the planner, hierarchical decomposer, code-as-policy generator, and
# GPT-5V scene perception. Without this, none of the agentic stack functions.
#   Get one: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DigitalOcean serverless-inference model-access key. Powers the /user page's
# scene perception (vision) + task planning (GPT-5.5 if your tier allows it,
# else an open-weights model such as llama-4-maverick). OpenAI-compatible
# endpoint at https://inference.do-ai.run/v1; the daemon reads it server-side
# so it never reaches the browser. The variable name is read verbatim.
#   Get one: DigitalOcean Control Panel → Gradient/GenAI → Model access keys
DigitalOcean=doo_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED FOR CLOUD DEPLOY + SKILL LIBRARY (Cloudflare)
# ─────────────────────────────────────────────────────────────────────────────
# Used by `wrangler deploy`, D1 (skill metadata), R2 (artifacts), Pages (UI).
#   Token: dash.cloudflare.com → My Profile → API Tokens → "Edit Cloudflare Workers" template
#   Account ID: dash.cloudflare.com → right sidebar of any zone/overview page
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED FOR FINE-TUNING (Modal)
# ─────────────────────────────────────────────────────────────────────────────
# Modal hosts the π0.5 LoRA training jobs that produce Layer-3 skills.
#   Get them: `pip install modal && modal token new` (writes ~/.modal.toml)
#   Then copy `token_id` and `token_secret` from that file.
MODAL_TOKEN_ID=ak-xxxxxxxxxxxxxxxxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────
# Publish captured demo datasets to a public HF dataset repo (F3).
#   Get one: https://huggingface.co/settings/tokens (write scope)
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Error reporting from worker + edge agent (G7).
#   Get one: sentry.io → your-project → Settings → Client Keys (DSN)
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oNNNNNNN.ingest.sentry.io/NNNNNNN

# ─────────────────────────────────────────────────────────────────────────────
# LOCAL OVERRIDES (rarely needed — defaults are usually fine)
# ─────────────────────────────────────────────────────────────────────────────
# Override the agent's home directory (default: ~/.farm).
# FARM_HOME=/path/to/farm-home

# Override the run-record output directory (default: $FARM_HOME/runs).
# FARM_RUNS_DIR=/path/to/runs

# Path to an alternate config file (default: $FARM_HOME/config.toml).
# FARM_CONFIG=/path/to/config.toml

# Auth token presented by the edge agent to the worker (when auth is enabled).
# FARM_API_KEY=farm_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
